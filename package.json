{
  "name": "vultd",
  "private": true,
  "version": "0.1.1",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "server": "node server/index.js",
    "dev:full": "concurrently \"npm run server\" \"vite --host\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:build": "vite build && electron-builder",
    "package:linux": "vite build && electron-builder --linux",
    "package:win": "vite build && electron-builder --win",
    "package:mac": "vite build && electron-builder --mac"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "bip39": "^3.1.0",
    "buffer": "^6.0.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "express": "^4.22.1",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1",
    "wait-on": "^9.0.5"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.vultd.wallet",
    "productName": "VULTD",
    "copyright": "Copyright \u00a9 2026 S6dative",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Finance",
      "synopsis": "Bitcoin-backed private stablecoin wallet",
      "description": "VULTD wallet for managing VUSD \u2014 a privacy-preserving Bitcoin-backed stablecoin on Lightning Network"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VULTD",
      "differentialPackage": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.finance"
    },
    "dmg": {
      "title": "VULTD ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "description": "VULTD \u2014 Bitcoin-backed private stablecoin wallet",
  "author": "S6dative",
  "copyright": "Copyright \u00a9 2026 S6dative"
}
